{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/src",
    "<rootDir>/src-hex",
    "<rootDir>/test"
  ],
  "testMatch": [
    "**/test/**/*.spec.ts",
    "**/test/**/*.test.ts",
    "**/__tests__/**/*.spec.ts",
    "**/__tests__/**/*.test.ts"
  ],
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/__mocks__/",
    "setup.ts",
    "test-utils.ts"
  ],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "src-hex/**/*.ts",
    "!src/**/*.d.ts",
    "!src/index.ts",
    "!src-hex/**/*.d.ts",
    "!index.ts"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/dist/"
  ],
  "moduleFileExtensions": [
    "ts",
    "js",
    "json"
  ],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "diagnostics": {
        "ignoreCodes": [6133, 6138, 6196]
      },
      "tsconfig": {
        "noUnusedLocals": false,
        "noUnusedParameters": false
      }
    }]
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@hex/(.*)$": "<rootDir>/src-hex/$1"
  },
  "setupFilesAfterFramework": [],
  "coverageThreshold": {
    "global": {
      "branches": 60,
      "functions": 70,
      "lines": 70,
      "statements": 70
    }
  }
}
