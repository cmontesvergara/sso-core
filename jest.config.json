{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/src-hex"
  ],
  "testMatch": [
    "**/__tests__/**/*.spec.ts",
    "**/__tests__/**/*.test.ts"
  ],
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/__mocks__/",
    "setup.ts",
    "test-utils.ts"
  ],
  "collectCoverageFrom": [
    "src-hex/**/*.ts",
    "!src-hex/**/*.d.ts",
    "!index.ts"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/dist/",
    "/__tests__/"
  ],
  "moduleFileExtensions": [
    "ts",
    "js",
    "json"
  ],
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "diagnostics": {
        "ignoreCodes": [6133, 6138, 6196]
      },
      "tsconfig": {
        "noUnusedLocals": false,
        "noUnusedParameters": false
      }
    }]
  },
  "moduleNameMapper": {
    "^@hex/(.*)$": "<rootDir>/src-hex/$1"
  },
  "coverageThreshold": {
    "global": {
      "branches": 60,
      "functions": 70,
      "lines": 70,
      "statements": 70
    }
  }
}
